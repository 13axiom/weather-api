# ─────────────────────────────────────────────────────────────────────────────
# weather-api — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Docker default — change for production)
DATABASE_URL=postgres://weather_user:weather_pass@localhost:5432/weather_db

# HTTP port
PORT=8080

# How often to sync weather AND air quality data (minutes).
# 60 = once per hour.  Change to 1440 for once per day after testing.
SYNC_INTERVAL_MINUTES=60

# Comma-separated city names to track (must be recognisable by Open-Meteo geocoding)
DEFAULT_CITIES=Moscow,London,New York,Tokyo,Sydney

# CORS — comma-separated allowed origins for the frontend
ALLOWED_ORIGINS=http://localhost:3000

# ─── OpenWeatherMap (Air Quality) ────────────────────────────────────────────
# Free API key from https://home.openweathermap.org/api_keys
# Free tier: 60 calls/minute, no monthly cap.
# Leave empty to disable air quality endpoints (weather still works fine).
OWM_API_KEY=

# ─── Internal API Key ─────────────────────────────────────────────────────────
# Protects /api/v1/air/* endpoints from public access.
# Generate with: openssl rand -hex 32
# The SAME value must be set in weather-ui/.env.local as NEXT_PUBLIC_INTERNAL_KEY
# Leave empty to skip auth check (fine for local development).
INTERNAL_API_KEY=
